    <string name="learning_result_passed_body">Great work. The training button now shows a crown because you scored at least 80%%.</string>
    <string name="learning_result_failed_body">No problem. Review the tips and try again until you reach 80%% or more.</string>
    <string name="learning_step_1_title">Read the health card</string>
    <string name="learning_step_1_body">The large top card gives you a quick snapshot. Start the scan there and watch the health index update when results arrive.</string>
    <string name="learning_step_2_title">Understand the risk stack</string>
    <string name="learning_step_2_body">High, medium and low risk cards help you group apps fast. Use them as a shortlist for what you want to inspect first.</string>
    <string name="learning_step_3_title">Use the search button</string>
    <string name="learning_step_3_body">The round search button is your quick entry point for browsing or filtering apps after the scan finishes.</string>
    <string name="learning_step_4_title">Finish with the quiz</string>
    <string name="learning_step_4_body">After the tutorial, complete a short quiz. If you score 80%% or more, the training button earns a crown.</string>
    <string name="quiz_q1_title">Which sign is the strongest warning signal?</string>
    <string name="quiz_q1_option_1">The app asks for SMS and microphone access without a clear reason.</string>
    <string name="quiz_q1_option_2">The app has a bright icon.</string>
    <string name="quiz_q1_option_3">The app uses a dark theme.</string>
    <string name="quiz_q2_title">What should you review before trusting a new app?</string>
    <string name="quiz_q2_option_1">Its permissions and description.</string>
    <string name="quiz_q2_option_2">Only the app icon.</string>
    <string name="quiz_q2_option_3">Nothing, just install it.</string>
    <string name="quiz_q3_title">If an app asks for camera permission but never uses the camera, what is the safest move?</string>
    <string name="quiz_q3_option_1">Review it and deny or remove the app if needed.</string>
    <string name="quiz_q3_option_2">Allow it forever.</string>
    <string name="quiz_q3_option_3">Share it with friends.</string>
    <string name="quiz_q4_title">Why do we run a scan?</string>
    <string name="quiz_q4_option_1">To group apps by visible risk indicators.</string>
    <string name="quiz_q4_option_2">To guarantee there is zero threat.</string>
    <string name="quiz_q4_option_3">To make the phone charge faster.</string>
    <string name="quiz_q5_title">What score gives the training button a crown?</string>
    <string name="quiz_q5_option_1">60%%</string>
    <string name="quiz_q5_option_2">80%%</string>
    <string name="quiz_q5_option_3">100%%</string>
